;border-right:1px solid var(--border-color)}.content{counter-reset:h1-counter;width:calc(100% - 320px);position:relative;float:right}.content #progress-bar{position:fixed;top:0;left:320px;right:0;height:4px;background:var(--primary);transform:scaleX(0);transform-origin:0 50%;transition:transform 0.1s;z-index:1000}@media screen and (max-width: 1000px){.content #progress-bar{left:0}}@media screen and (max-width: 1000px){.content{width:100%;float:none}}.content .toggle{position:absolute;top:5px;left:5px}section:last-of-type{padding-bottom:300px}section>p,section>ul,section>ol,section>div,section>table{text-align:justify;padding-left:5%;padding-right:5%;box-sizing:border-box}section pre,section .highlight pre,.highlight section pre,section .highlight .hll,.highlight section .hll{margin-left:5%;margin-right:5%}section>ol{padding-left:calc(5% + 40px)}h1,h2,h3,h4,h5,h6{text-transform:uppercase;font-weight:700;line-height:1.2;color:var(--primary);transition:color var(--transition-speed)}h1{font-size:2.8em;padding:40px 0 10px;text-align:right;border-bottom:var(--primary) 8px solid;width:100%;margin:0 0 30px}h1:before{content:counter(h1-counter) " ";opacity:0.3}.h1{counter-increment:h1-counter;counter-reset:h2-counter;padding-top:80px}h2{font-size:1.8em;padding:35px 0 10px;width:90%;text-align:center;border-bottom:4px solid var(--primary);margin:0 auto 25px}h2:before{content:counter(h1-counter) "." counter(h2-counter) " ";opacity:0.3}.h2{counter-increment:h2-counter;counter-reset:h3-counter;padding-top:60px}h3{font-size:1.7em;padding:20px 0 0;width:90%;text-align:left;border-bottom:4px solid #385958;margin:0 auto 20px;line-height:0.65}h3:before{content:counter(h1-counter) "." counter(h2-counter) "." counter(h3-counter) " "}.h3{counter-increment:h3-counter;counter-reset:h4-counter;padding-top:40px}h4{font-size:1.5em;padding:18px 0 0;width:90%;text-align:left;border-bottom:3px solid #385958;margin:0 auto 18px;line-height:0.67}h4:before{content:counter(h1-counter) "." counter(h2-counter) "." counter(h3-counter) "." counter(h4-counter) " "}.h4{counter-increment:h4-counter;counter-reset:h5-counter 1;padding-top:30px}h5{font-size:1.3em;padding:40px 0 0;width:90%;text-align:left;border-bottom:2px solid #385958;margin:0 auto 15px;line-height:0.68}h5:before{content:counter(h1-counter) "." counter(h2-counter) "." counter(h3-counter) "." counter(h4-counter) "." counter(h5-counter) " "}a{transition:var(--transition-speed) all;color:var(--primary);text-decoration:none}.content a{border-bottom:var(--primary) 1px solid;padding:0px 2px}.content a:hover{background:var(--primary-light);border-bottom-color:transparent}a:hover{color:var(--primary-dark)}img{display:block;max-width:100%;margin:30px auto;border-radius:8px;box-shadow:var(--card-shadow)}table{margin:30px auto;width:90%;border-collapse:collapse;font-size:0.95em;border:1px solid var(--border-color);background:var(--card-bg);border-radius:8px;overflow:hidden}table th,table td{padding:12px 15px;border-bottom:1px solid var(--border-color)}table th{background:var(--sidebar-bg);font-weight:700;color:var(--primary);text-transform:uppercase;font-size:0.8em;letter-spacing:1px}table tr:last-child td{border-bottom:0}table tr:hover{background-color:var(--primary-light)}@media screen and (max-width: 600px){table{width:100%;font-size:0.85em}table th,table td{padding:10px}}code{font-family:'Overpass', 'Overpass-mono', monospace}.video_container{margin:30px auto;position:relative;width:90%;height:0;padding:51.34228188% 0 0 0}#intro{padding-top:20px}code,pre,.highlight pre,.highlight .hll{white-space:pre-wrap;border-radius:0px;border:0}iframe{padding-left:5%;padding-right:5%;box-sizing:border-box;width:100%}p+p{margin-top:20px}.sidebar-header{padding:24px;display:flex;flex-direction:column;align-items:flex-start;border-bottom:1px solid var(--border-color);background:var(--header-bg);position:relative}.sidebar-header .logo-link{margin-bottom:15px}.sidebar-header .logo-link .logo{height:256px;width:auto;transition:opacity var(--transition-speed)}.sidebar-header .logo-link .logo:hover{opacity:0.8}.sidebar-header header{background:none;height:auto;padding:5px 0;margin-bottom:20px}.sidebar-header header span{position:static;transform:none;color:var(--primary);font-size:1.2rem;letter-spacing:1px;font-weight:700}.header-controls{display:flex;align-items:center;gap:15px;width:100%;justify-content:flex-start}#theme-toggle{background:none;border:1px solid var(--border-color);border-radius:50%;width:40px;height:40px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text-color);transition:all var(--transition-speed)}#theme-toggle:hover{border-color:var(--primary);color:var(--primary);background:var(--primary-light)}#theme-toggle .sun{display:block;fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}#theme-toggle .moon{display:none;fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}[data-theme='dark'] #theme-toggle .sun{display:none}[data-theme='dark'] #theme-toggle .moon{display:block}.toggle:hover{cursor:pointer;opacity:.8}@media screen and (min-width: 1001px){.toggle{display:none}}.overview{position:fixed;top:0px;left:0px;height:100%;overflow-y:auto;transition:var(--transition-speed) all;background:var(--sidebar-bg);border-right:1px solid var(--border-color)}@media screen and (max-width: 1000px){.overview{left:-320px;transition:.3s all ease;transform:translate(0, 0);z-index:100}.overview.open{transform:translate(320px, 0)}}.overview .toggle{position:absolute;top:5px;right:5px;z-index:100}.overview ul{list-style:none;counter-reset:nested-counter;padding-left:0}.overview ul li{counter-increment:nested-counter;font-size:98%}.overview #nav{width:100%;box-sizing:border-box;padding:20px 0}.overview #nav>li a{display:block;padding:12px 24px;line-height:1.2;border-bottom:1px solid var(--border-color);color:var(--text-color)}.overview #nav>li a:hover{background:var(--primary-light);color: